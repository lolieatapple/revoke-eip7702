# Private key of the hijacked address (used to sign the revoke authorization)
HIJACKED_PRIVATE_KEY=0xYOUR_HIJACKED_ADDRESS_PRIVATE_KEY

# Private key of the gas payer address (must have Sepolia ETH)
SENDER_PRIVATE_KEY=0xYOUR_GAS_PAYER_PRIVATE_KEY

# Sepolia RPC endpoint
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
